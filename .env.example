# Copy to .env and fill in. Loaded automatically by internal/config.FromEnv().
# See COMMANDS.md §4 for where to obtain each credential. The core pipeline
# (World Bank + Wikidata + JSON seeds) needs none of these.

# GDELT events (BigQuery). Also run: gcloud auth application-default login
GDELT_GCP_PROJECT=
# GDELT_MODE=aggregated    # aggregated (default): full GDELT aggregated in BigQuery
#                          # → ~2.4M SNAPSHOT_EDGEs in agg DB (~1.5-2GB, fits local disk).
#                          # raw: stream every EVENT edge into raw DB (16-48GB, needs disk).
# GDELT_MAX_ROWS=          # optional per-segment cap (raw mode); leave unset for full data
# GDELT_START_DATE=2010-01-01
# GDELT_END_DATE=

# ACLED conflict feature (myACLED account, OAuth)
ACLED_EMAIL=
ACLED_PASSWORD=

# file-based sources (download per COMMANDS.md §4)
VDEM_CSV_PATH=
SIPRI_XLSX_PATH=
UNDP_HDI_CSV_PATH=

# Weights & Biases (ML training tracking; see services/ml + plans/03-ml-workflow.md §4.4)
# On Kaggle set WANDB_API_KEY as a notebook Secret instead of putting it here.
WANDB_API_KEY=
WANDB_ENTITY=anna-nechytailenko-kyiv-school-of-economics
WANDB_PROJECT=geosimulation

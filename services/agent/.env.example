# Optional agent configuration. Copy to `.env` (same directory) and edit — the agent loads it
# automatically at startup (existing shell env always wins). Everything here is OPTIONAL:
#
#   * GEO_DATA_DIR / GEO_ARTIFACTS_DIR are AUTO-DISCOVERED from the repo, so you do NOT need to
#     set them. Only set them to override (use ABSOLUTE paths — do not use $PWD in a .env file).
#   * The LLM/explainer knobs below all have sensible defaults.

# ---- model bundle (optional; auto-discovered if unset) ----
# GEO_ARTIFACTS_DIR=/absolute/path/to/geopolitic/artifacts
# GEO_DATA_DIR=/absolute/path/to/geopolitic/services/ml/dataset_parquet

# ---- LLM (defaults: local Ollama) ----
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:3b-instruct
# OLLAMA_BASE_URL=http://localhost:11434
# To use a cloud model instead (no Ollama needed): LLM_PROVIDER=anthropic + ANTHROPIC_API_KEY=...

# ---- explainer cost (the viz step explains every answer; lower = faster, coarser masks) ----
GNN_EXPLAINER_EPOCHS=64
IG_STEPS=24

# ---- serving (optional) ----
# AGENT_HOST=127.0.0.1
# AGENT_PORT=8100
